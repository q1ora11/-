#include <iostream>
#include <string>
using namespace std;

int main() {
	setlocale(LC_ALL, "");

	string s;
	int N;
	int count = 0;

	cout << "Введите строку: ";
	getline(cin, s);

	cout << "Введите число N: ";
	cin >> N;

	int len = 0; 

	for (char c : s) {
		if (c != ' ') {
			len++; 
		}
		else {
			if (len > 0) {        
				if (len != N) count++; 
				len = 0;           
			}
		}
	}

	if (len > 0 && len != N) count++;

	cout << "число слов с длиной не равной " << N << ": " << count << endl;

	return 0;
}
