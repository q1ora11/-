#include <iostream>
using namespace std;
int main() {
	setlocale(LC_ALL, "");
	int mass[3][4] = {
		{0,9,8,15},
		{1,7,2,5},
		{2,8,1,3},
	};

	int k;
	std::cout << "Введите число k: ";
	std::cin >> k;
	int nov[3];
	for (int j = 1; j < 4; j++) {
		nov[j - 1] = mass[k][j];
	}
	int indices[3] = { 1, 2, 3 };

	for (int i = 0; i < 2; i++) {
		for (int j = 0; j < 2 - i; j++) {
			if (nov[indices[j] - 1] > nov[indices[j + 1] - 1]) {
				int temp = indices[j];
				indices[j] = indices[j + 1];
				indices[j + 1] = temp;
			}
		}
	}
	int result[3][4];

	for (int i = 0; i < 3; i++) {
		result[i][0] = mass[i][0];
		

	}

	for (int i = 0; i < 3; i++) {          
		for (int j = 0; j < 3; j++) {      
			result[i][j + 1] = mass[i][indices[j]];
		}
	}

	cout << "Результат:" << endl;
	for (int i = 0; i < 3; i++) {
		for (int j = 0; j < 4; j++) {
			cout << result[i][j] << " ";
		}
		cout << endl;
	}
return 0;
}
